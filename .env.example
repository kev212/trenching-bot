# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# MiMo API
MIMO_API_KEY=your_mimo_api_here

# GMGN API
GMGN_API_KEY=your_gmgn_api_key_here

# Proxy (required for GMGN, blocks datacenter IPs)
HTTP_PROXY=http://user:pass@host:port

# Trading bot (Phase 1: paper mode)
PAPER_MODE=true
PAPER_STARTING_BALANCE_SOL=10.0
CONFIDENCE_AUTO_EXECUTE=0.75

# Helius RPC (Phase 2: needed for live trading)
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# Fernet-encrypted private key (Phase 2 only)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
PRIVATE_KEY_ENCRYPTED=
WALLET_PUBKEY=

# Optional
LOG_LEVEL=INFO
