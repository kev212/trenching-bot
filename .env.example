# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# MiMo API
MIMO_API_KEY=your_mimo_api_here

# GMGN API key (used by sources/gmgn.py for V1 reads: trending, info, security, holders)
GMGN_API_KEY=your_gmgn_api_key_here

# Proxy (required for GMGN V1 API, blocks datacenter IPs)
HTTP_PROXY=http://user:pass@host:port

# Trading bot (Phase 1: paper mode)
PAPER_MODE=true
PAPER_STARTING_BALANCE_SOL=10.0
CONFIDENCE_AUTO_EXECUTE=0.75

# Helius RPC (Phase 2: live trading — for fetching on-chain SOL balance)
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# Live trading (Phase 2): Solana wallet keypair
# Generate with:
#   python -c "import base58; from solders.keypair import Keypair; k=Keypair(); print('WALLET_PUBKEY=' + str(k.pubkey())); print('WALLET_PRIVATE_KEY=' + base58.b58encode(bytes(k)).decode())"
WALLET_PRIVATE_KEY=
WALLET_PUBKEY=

# Live trading uses gmgn-cli (https://github.com/GMGNAI/gmgn-skills)
# Install: sudo npm install -g gmgn-cli
# Credentials live in ~/.config/gmgn/.env (not in this file):
#   GMGN_API_KEY=<key>
#   GMGN_PRIVATE_KEY="<pem content>"

# Optional
LOG_LEVEL=INFO
